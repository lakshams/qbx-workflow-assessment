    {
      "parameters": {
        "jsCode": "// Get all incoming items (n8n standard)\nconst items = $input.all();\n\n// Required fields\nconst requiredFields = [\"incidentId\", \"severity\", \"title\", \"createdAt\"];\n\n// Severity mapping\nconst severityMap = {\n  P1: 1,\n  P2: 2,\n  P3: 3,\n  P4: 4\n};\n\nreturn items.map((item) => {\n  const body = item.json.body;\n\n  // 1) Validate body\n  if (!body || typeof body !== \"object\") {\n    throw new Error(\"Request body is missing\");\n  }\n\n  // 2) Validate required fields\n  const missingFields = requiredFields.filter((f) => !body[f]);\n  if (missingFields.length > 0) {\n    // Join names so you see exactly which are missing\n    const fields = missingFields.join(\", \");\n    throw new Error(`Missing required field(s): ${fields}`);\n  }\n\n  // 3) Validate & map severity\n  const severityLevel = severityMap[body.severity];\n  if (!severityLevel) {\n    throw new Error(`Validation failed: Invalid severity value: ${body.severity}`);\n  }\n\n  // 4) Truncate description to 240 chars (if present)\n  let description = body.description || \"\";\n  if (typeof description === \"string\" && description.length > 240) {\n    description = description.substring(0, 240);\n  }\n\n  // 5) Generate dedupeKey\n  const dedupeKey = `${body.incidentId}-${body.createdAt}`;\n\n  // 6) Build normalized incident object\n  const normalized = {\n    incidentId: body.incidentId,\n    severity: body.severity,\n    severityLevel,\n    title: body.title,\n    description,\n    createdAt: body.createdAt,\n    ownerEmail: body.ownerEmail,\n    sourceSystem: body.sourceSystem,\n    storeId: body.storeId,\n    metadata: body.metadata,\n    dedupeKey\n  };\n\n  // Return in n8n item format\n  return { json: normalized };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1312,
        448
      ],
      "id": "8a9f974b-2ad0-4c49-a564-6f122e120e47",
      "name": "Normalize Incident"
    },
    {
      "parameters": {
        "jsCode": "const incident = $json;\n\nconst message = `🚨 Incident Alert\n\nID: ${incident.incidentId}\nSeverity: ${incident.severity}\nTitle: ${incident.title}\n\nDescription:\n${incident.description}\n\nCreated At: ${incident.createdAt}`;\n\n// initialize retry counter\nconst retryCount = 1;\n\nreturn [\n  {\n    json: {\n      ...incident,\n      message,\n      retryCount\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1088,
        448
      ],
      "id": "fd1036b7-69f2-4291-ad99-70c300d9b6dc",
      "name": "Format Message"
    },
    {
      "parameters": {
        "jsCode": "const data = $json;\n\n// persistent workflow storage\nconst store = $getWorkflowStaticData('global');\n\nif (!store.processedIncidents) {\n  store.processedIncidents = {};\n}\n\nconst key = data.dedupeKey;\n\n// if duplicate, stop workflow\nif (store.processedIncidents[key]) {\n  console.log(`Duplicate detected: ${key}`);\n  return [];   // stops downstream nodes\n}\n\n// store new key\nstore.processedIncidents[key] = true;\n\nreturn [{ json: data }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
