      "id": "ed288320-5771-40cf-ad1d-37eb8e1afbe3",
      "name": "O365 Email",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        -640,
        592
      ],
      "retryOnFail": false,
